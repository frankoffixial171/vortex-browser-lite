<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.VortexBrowser" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/vortex_primary</item>
        <item name="colorPrimaryDark">@color/vortex_primary_dark</item>
        <item name="colorAccent">@color/vortex_accent</item>
        <item name="android:statusBarColor">@color/toolbar_bg</item>
        <item name="android:navigationBarColor">@color/toolbar_bg</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:windowBackground">@color/background</item>
    </style>

    <style name="Theme.VortexBrowser.Settings" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/vortex_primary</item>
        <item name="colorPrimaryDark">@color/vortex_primary_dark</item>
        <item name="colorAccent">@color/vortex_accent</item>
    </style>
</resources>
